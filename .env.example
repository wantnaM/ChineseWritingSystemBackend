# =============================================================================
# 语文一体化学习平台 · 后端环境变量模板
# 使用方法: cp .env.example .env  然后填入真实值
# 注意: .env 已加入 .gitignore，请勿将真实密钥提交到版本库
# =============================================================================


# -----------------------------------------------------------------------------
# 数据库 (PostgreSQL)
# -----------------------------------------------------------------------------

# 异步连接串，驱动固定使用 asyncpg
# 格式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/writing_system

# 连接池配置（可选，使用默认值即可）
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# LangGraph Checkpoint 缓存 & 会话状态
# 格式: redis://[:<password>@]<host>:<port>/<db>
REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# Anthropic API
# -----------------------------------------------------------------------------

# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 评测使用的模型（可选，默认 claude-sonnet-4-20250514）
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 单次评测最大 token 数（可选）
# ANTHROPIC_MAX_TOKENS=1000


# -----------------------------------------------------------------------------
# JWT 认证
# -----------------------------------------------------------------------------

# 签名密钥：生产环境请替换为随机长字符串
# 生成示例: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-please-change-in-production

# 签名算法（默认 HS256，无需修改）
JWT_ALGORITHM=HS256

# Token 有效期（秒），默认 86400 = 24 小时
JWT_EXPIRE_SECONDS=86400


# -----------------------------------------------------------------------------
# CORS（跨域）
# -----------------------------------------------------------------------------

# 允许的前端来源，JSON 数组格式
# 本地开发默认放行 Vite 开发服务器
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]


# -----------------------------------------------------------------------------
# 应用基础配置
# -----------------------------------------------------------------------------

# 运行环境: development | production
APP_ENV=development

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 服务监听端口（uvicorn 启动时也可通过命令行 --port 指定）
PORT=8000
