# =============================================================================
# Docker 部署环境变量配置
# =============================================================================
# 使用方法:
#   1. 复制此文件为 .env:  cp docker/.env.docker .env
#   2. 修改其中的敏感信息（密码、API Key 等）
#   3. 运行: docker-compose -f docker/docker-compose.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库 (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=writing_system
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# AI API 配置（必填）
# -----------------------------------------------------------------------------
# Anthropic API Key（可选）
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Kimi API Key（可选，推荐使用）
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-2.5

# -----------------------------------------------------------------------------
# JWT 认证（生产环境必须修改）
# -----------------------------------------------------------------------------
# 生成密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_key_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=86400

# -----------------------------------------------------------------------------
# CORS（根据前端地址修改）
# -----------------------------------------------------------------------------
# 生产环境示例: CORS_ORIGINS=["https://your-domain.com"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
API_PORT=8000
